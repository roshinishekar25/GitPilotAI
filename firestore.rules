rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidAnalysis(data) {
      return data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 512
        && data.url is string && data.url.size() <= 2048
        && data.stats is string && data.stats.size() <= 512
        && data.description is string && data.description.size() <= 10000
        && data.language is string && data.language.size() <= 255
        && data.color is string && data.color.size() <= 128
        && (data.risks == null || (data.risks is string && data.risks.size() <= 5000))
        && (data.roadmap == null || data.roadmap is list)
        && (data.importantFiles == null || data.importantFiles is list)
        && (data.status == null || (data.status is string && data.status.size() <= 255));
    }

    function isValidUserProfile(data) {
      return (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.email == null || (data.email is string && data.email.size() <= 200))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && data.updatedAt == request.time;
    }

    // --- Rules ---

    match /analyses/{analysisId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidAnalysis(incoming())
        && incoming().createdAt == request.time;

      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isValidAnalysis(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'url', 'stats', 'description', 'language', 'color', 
          'roadmap', 'risks', 'importantFiles', 'status', 'updatedAt'
        ]);

      allow delete: if isOwner(existing().userId);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevention of PII scraping

      allow create: if isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().keys().hasAll(['updatedAt']); // Minimum required

      allow update: if isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'photoURL', 'updatedAt']);

      allow delete: if false; // Profiles usually shouldn't be deleted by clients
    }
  }
}
